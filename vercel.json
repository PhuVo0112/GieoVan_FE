{
    "rewrites": [
        {
            "source": "/api/login",
            "destination": "https://gieovan.onrender.com/api/login"
        },
        {
            "source": "/api/poems(.*)",
            "destination": "https://gieovan.onrender.com/api/poems$1"
        },
        {
            "source": "/login",
            "destination": "/login.html"
        },
        {
            "source": "/register",
            "destination": "/register.html"
        },
        {
            "source": "/feed",
            "destination": "/feed.html"
        },
        {
            "source": "/archive",
            "destination": "/archive.html"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}